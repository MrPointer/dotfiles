# Shared helpers for coding agents launched through nono.

function _nono_agent_ensure_ssh_signing_key() {
  local public_key="$1"
  local private_key="${2:-${public_key%.pub}}"

  [[ -n "${SSH_AUTH_SOCK:-}" ]] || return 0
  command -v ssh-add >/dev/null 2>&1 || return 0
  [[ -r "$public_key" ]] || return 0

  ssh-add -T "$public_key" >/dev/null 2>&1 && return 0
  [[ -r "$private_key" ]] || return 0

{{- if eq .chezmoi.os "darwin" }}
  ssh-add --apple-use-keychain "$private_key" >/dev/null 2>&1 || ssh-add -q "$private_key" || true
{{- else }}
  ssh-add -q "$private_key" || true
{{- end }}
}

function _nono_agent_ensure_ssh_signing_keys() {
  while (( $# >= 2 )); do
    _nono_agent_ensure_ssh_signing_key "$1" "$2"
    shift 2
  done
}

function _nono_agent_run() {
  local profile="$1"
  local git_config="$2"
  local command_name="$3"
  local public_key="$4"
  local private_key="$5"
  shift 5

  _nono_agent_ensure_ssh_signing_key "$public_key" "$private_key"

  local -a ssh_agent_args=()
  if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
    ssh_agent_args=(--allow-unix-socket "$SSH_AUTH_SOCK")
  fi

  GIT_CONFIG_GLOBAL="$git_config" nono run --profile "$profile" --allow-cwd "${ssh_agent_args[@]}" -- "$command_name" "$@"
}
