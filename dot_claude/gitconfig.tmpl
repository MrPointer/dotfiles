[include]
   path = {{ .chezmoi.homeDir }}/.config/git/common.gitconfig
[user]
{{- if and .personal.work_env (eq .personal.work_name "sedg") }}
   signingkey = {{ .chezmoi.homeDir }}/.ssh/id_rsa_sedg.pub
{{- else }}
   signingkey = {{ .chezmoi.homeDir }}/.ssh/id_ed25519.pub
{{- end }}
[gpg]
   format = ssh
