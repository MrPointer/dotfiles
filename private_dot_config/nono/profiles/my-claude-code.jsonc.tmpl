{
   "$schema": "../schemas/nono-profile.schema.json",
   "extends": [
      "claude-code"
   ],
   "meta": {
      "name": "my-claude-code"
   },
   "filesystem": {
      "allow": [
         "$XDG_CACHE_HOME/uv",
         "$XDG_DATA_HOME/uv/tools", // Mostly for semble search
         "$XDG_CACHE_HOME/huggingface/hub/models--minishlab--potion-code-16M", // Semble model cache
         "$HOME/.azure",
         "$HOME/.azure-devops",
         "$TMPDIR"
      ],
      "read": [
         "$HOME/.agents/skills",
         "$HOME/lcp-docs",
         "$HOME/.context7"
      ],
      "write": [
         "$HOME/Applications/Claude Code URL Handler.app/Contents/MacOS"
      ],
      "allow_file": [],
      "read_file": [
         "$HOME/.ssh/id_rsa_{{ .personal.work_name }}.pub",
         "$HOME/.ssh/id_ed25519_{{ .personal.work_name }}.pub",
         "$HOME/.ssh/known_hosts",
         "$HOME/.ssh/config",
         "$XDG_CONFIG_HOME/git/common.gitconfig",
         "$XDG_CONFIG_HOME/worktrunk/config.toml"
      ],
      "write_file": [],
      "deny": [],
      "bypass_protection": [
         "$HOME/.ssh/id_rsa_{{ .personal.work_name }}.pub",
         "$HOME/.ssh/id_ed25519_{{ .personal.work_name }}.pub",
         "$HOME/.ssh/known_hosts",
         "$HOME/.ssh/config",
         "$HOME/.azure"
      ],
      "suppress_save_prompt": [
         "/Users",
         "$HOME",
         "$HOME/Library/Application Support/Microsoft Edge",
         "$HOME/Projects",
         "$HOME/Projects/sedg",
         "$HOME/Projects/sedg/hark"
      ]
   },
   "network": {
      "block": false,
      "network_profile": "claude-code",
      "allow_domain": [
         "mcp.context7.com",
         "mcp.atlassian.com",
         "mcp-proxy.anthropic.com",
         "gitlab.solaredge.com",
         "solaredge-prod.atlassian.net",
         "dev.azure.com",
         "balena.io",
         "balena-cloud.com",
         "edge-controller-2.internal.hark.network"
      ]
   },
   "env_credentials": {},
   "environment": null,
   "workdir": {
      "access": "readwrite"
   }
}
