{
   "$schema": "../schemas/nono-profile.schema.json",
   "extends": [
      "opencode"
   ],
   "meta": {
      "name": "my-opencode",
      "description": "Generic opencode profile for daily dev work"
   },
   "filesystem": {
      "allow": [
         "$XDG_CACHE_HOME/uv",
         "$XDG_DATA_HOME/uv/tools", // Mostly for semble search
         "$XDG_CACHE_HOME/huggingface/hub/models--minishlab--potion-code-16M-v2", // Semble model cache
         "$HOME/.npm/_cacache"
      ],
      "read": [
         "$HOME/.agents/skills",
         "$HOME/lcp-docs",
         "$HOME/Library/Caches/semble/" // Semble's internal stats
      ],
      "write": [],
      "allow_file": [],
      "read_file": [
         "$HOME/.ssh/id_ed25519.pub",
         "$HOME/.ssh/known_hosts",
         "$HOME/.ssh/config",
         "$HOME/.local/bin/nono-git-ssh",
         "$XDG_CONFIG_HOME/git/common.gitconfig",
         "$XDG_CONFIG_HOME/git/allowed_signers",
         "$XDG_CONFIG_HOME/worktrunk/config.toml",
         "$XDG_CONFIG_HOME/gh/config.yml",
         "$XDG_CONFIG_HOME/gh/hosts.yml"
      ],
      "write_file": [],
      "deny": [],
      "bypass_protection": [
         "$HOME/.ssh/id_ed25519.pub",
         "$HOME/.ssh/known_hosts",
         "$HOME/.ssh/config"
      ],
      "suppress_save_prompt": [
         "/Users",
         "/System",
         "$HOME",
         "$HOME/.claude",
         "$HOME/.claude/ide",
         "$XDG_CONFIG_HOME",
         "$HOME/Library/Application Support/Zed/db/0-stable/db.sqlite"
      ]
   },
   "network": {
      "block": false,
      "network_profile": "developer",
      "allow_domain": [
         "chatgpt.com",
         "openai.com",
         "mcp.context7.com"
      ]
   },
   "environment": null,
   "workdir": {
      "access": "readwrite"
   }
}
