#!/usr/bin/env bash
set -euo pipefail

# Ensures baseline Claude Code permissions exist in .claude/settings.local.json
# without overwriting any existing permissions. Intended to be called from
# worktrunk's post-create hook so new worktrees inherit tool permissions.

if [[ ! -d .git ]] && ! git rev-parse --git-dir &>/dev/null 2>&1; then
    echo "Error: must be run from a git repository root." >&2
    exit 1
fi

SETTINGS_DIR=".claude"
SETTINGS_FILE="$SETTINGS_DIR/settings.local.json"

BASELINE_PERMISSIONS=(
    "Write"
    "Edit"
    "MultiEdit"
)

if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed. Please install it manually (e.g., brew install jq)." >&2
    exit 1
fi

mkdir -p "$SETTINGS_DIR"

if [[ -f "$SETTINGS_FILE" ]]; then
    existing="$(cat "$SETTINGS_FILE")"
else
    existing='{"permissions":{"allow":[]}}'
fi

# Build a jq filter that adds each missing permission
filter='. as $root | $root'
for perm in "${BASELINE_PERMISSIONS[@]}"; do
    filter+=" | if (.permissions.allow | index(\"$perm\")) then . else .permissions.allow += [\"$perm\"] end"
done

echo "$existing" | jq "$filter" > "$SETTINGS_FILE"
