#!/bin/bash
set -euo pipefail

# Keep the local nono profile schema fresh for editor completions in both the
# chezmoi source tree and the applied target tree. The schema is generated by
# the installed nono binary, so chezmoi externals cannot fetch it directly.

if ! command -v nono >/dev/null 2>&1; then
  exit 0
fi

refresh_seconds=$((3 * 24 * 60 * 60))
now=$(date +%s)
nono_version=$(nono --version 2>/dev/null || true)

source_schema="{{ .chezmoi.sourceDir }}/private_dot_config/nono/schemas/nono-profile.schema.json"
target_schema="${XDG_CONFIG_HOME:-$HOME/.config}/nono/schemas/nono-profile.schema.json"
stamp_dir="${XDG_CACHE_HOME:-$HOME/.cache}/chezmoi"
stamp_file="$stamp_dir/nono-profile-schema.stamp"

last_refresh=0
last_version=""
if [[ -f "$stamp_file" ]]; then
  {
    IFS= read -r last_refresh || true
    IFS= read -r last_version || true
  } <"$stamp_file"
fi

if [[ "$last_refresh" =~ ^[0-9]+$ ]] && \
   (( now - last_refresh < refresh_seconds )) && \
   [[ "$last_version" == "$nono_version" ]] && \
   [[ -f "$source_schema" ]] && \
   [[ -f "$target_schema" ]]; then
  exit 0
fi

tmp_schema=$(mktemp)
trap 'rm -f "$tmp_schema"' EXIT

nono profile schema >"$tmp_schema"

mkdir -p "$(dirname "$source_schema")" "$(dirname "$target_schema")" "$stamp_dir"

if [[ ! -f "$source_schema" ]] || ! cmp -s "$tmp_schema" "$source_schema"; then
  cp "$tmp_schema" "$source_schema"
fi

if [[ ! -f "$target_schema" ]] || ! cmp -s "$tmp_schema" "$target_schema"; then
  cp "$tmp_schema" "$target_schema"
fi

{
  printf '%s\n' "$now"
  printf '%s\n' "$nono_version"
} >"$stamp_file"
